# Copy to .env and adjust. All settings are optional — defaults reproduce the
# benchmark-tuned values. Prefix is PARSER_. See app/config.py.

# --- Upload limit ---
# Reject uploads larger than this many MB with HTTP 413. 0 disables the cap.
# PARSER_MAX_FILE_MB=100

# --- Routing ---
# Off: route purely by filename extension. On: also sniff content with
# libmagic and re-route mislabeled PDFs/images (a PNG named .pdf) or rescue
# extension-less uploads. Office/text subtypes always stay extension-routed.
# PARSER_VERIFY_MIME=false

# --- Logging ---
# DEBUG surfaces per-page/per-field graceful-degradation logs (PDF column
# extraction failures, email charset fallbacks, OMML conversion misses) that
# are otherwise quiet. Worker-side logs are captured and re-emitted by the API.
# PARSER_LOG_LEVEL=INFO

# --- Converter timeouts (seconds) ---
# PARSER_MARKITDOWN_TIMEOUT_S=60
# PARSER_PANDOC_RTF_TIMEOUT_S=45
# PARSER_PANDOC_HTML_TIMEOUT_S=45
# PARSER_PANDOC_DOCX_TIMEOUT_S=120
# PARSER_SOFFICE_TIMEOUT_S=120

# --- PDF scanned-document guard ---
# Average text chars/page below which a PDF is refused as image-only (422).
# PARSER_OCR_DENSITY_THRESHOLD=100

# --- mbox caps ---
# PARSER_MBOX_MAX_MESSAGES=10000
# PARSER_MBOX_MAX_OUTPUT_MB=50

# --- Image OCR ---
# Engine: tesseract | gemini | auto  (auto = gemini if a key is set, else tesseract)
# PARSER_IMAGE_OCR_ENGINE=auto
# PARSER_TESSERACT_LANG=eng
# PARSER_IMAGE_OCR_TIMEOUT_S=120
# Gemini (requires `uv sync --extra gemini`):
# PARSER_GEMINI_API_KEY=
# PARSER_GEMINI_MODEL=gemini-2.5-flash
