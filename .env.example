# Copy to .env and adjust. All settings are optional — defaults reproduce the
# benchmark-tuned values. Prefix is PARSER_. See app/config.py.

# --- Upload limit ---
# Reject uploads larger than this many MB with HTTP 413. 0 disables the cap.
# PARSER_MAX_FILE_MB=100

# --- Security: decompression-bomb guard (OOXML .docx/.xlsx/.pptx zips) ---
# The upload cap above bounds only compressed bytes; these bound what an
# archive may expand to (HTTP 413 if breached). Generous defaults clear all
# real documents.
# PARSER_ZIPBOMB_MAX_UNCOMPRESSED_MB=1024
# PARSER_ZIPBOMB_MAX_ENTRIES=10000
# PARSER_ZIPBOMB_MAX_RATIO=200

# --- Security: optional malware-scan hook ---
# Shell command run on every upload before parsing; the file path is appended
# as the final arg. Non-zero exit rejects the file (HTTP 422). Unset = no scan.
# PARSER_SCAN_COMMAND="clamdscan --no-summary --fdpass"
# PARSER_SCAN_TIMEOUT_S=60

# --- Metadata ---
# Every response carries a normalized `metadata` dict (title/author/dates,
# page/slide/sheet counts, source filename). `language` is detected from the
# markdown body with langdetect — disable it or shrink the sample to save the
# per-request cost.
# PARSER_DETECT_LANGUAGE=true
# PARSER_LANGUAGE_SAMPLE_CHARS=2000

# --- Routing ---
# Off: route purely by filename extension. On: also sniff content with
# libmagic and re-route mislabeled PDFs/images (a PNG named .pdf) or rescue
# extension-less uploads. Office/text subtypes always stay extension-routed.
# PARSER_VERIFY_MIME=false

# --- Logging ---
# DEBUG surfaces per-page/per-field graceful-degradation logs (PDF column
# extraction failures, email charset fallbacks, OMML conversion misses) that
# are otherwise quiet. Worker-side logs are captured and re-emitted by the API.
# PARSER_LOG_LEVEL=INFO

# --- Embedded-image OCR (figures inside PPTX/DOCX) ---
# OFF by default. When on, raster images inside PPTX slides and DOCX
# (word/media) are OCR'd with the image engine and appended under a
# "## Embedded image text" section. PDFs aren't covered yet. Bounded by a
# min-dimension filter, dedup, a per-doc count cap, and a time budget.
# DOCX runs in-process — prefer tesseract there (Gemini network calls aren't
# SIGKILL-protected on that path).
# PARSER_OCR_EMBEDDED_IMAGES=false
# PARSER_EMBEDDED_IMAGE_MIN_DIMENSION=64
# PARSER_EMBEDDED_IMAGES_MAX_PER_DOC=20
# PARSER_EMBEDDED_IMAGE_OCR_BUDGET_S=60

# --- Concurrency ceiling (per uvicorn worker) ---
# Max heavy parses (legacy soffice + isolated-worker formats) running at once
# in one worker; excess requests queue instead of spawning more subprocesses.
# Cluster concurrency = UVICORN_WORKERS x this — size vs PARSER_MEM_LIMIT.
# PARSER_MAX_CONCURRENT_HEAVY_PARSES=4

# --- Converter timeouts (seconds) ---
# PARSER_MARKITDOWN_TIMEOUT_S=60
# PARSER_PANDOC_RTF_TIMEOUT_S=45
# PARSER_PANDOC_HTML_TIMEOUT_S=45
# PARSER_PANDOC_DOCX_TIMEOUT_S=120
# PARSER_SOFFICE_TIMEOUT_S=120

# --- PDF scanned-document guard ---
# Average text chars/page below which a PDF is refused as image-only (422).
# PARSER_OCR_DENSITY_THRESHOLD=100

# --- mbox caps ---
# PARSER_MBOX_MAX_MESSAGES=10000
# PARSER_MBOX_MAX_OUTPUT_MB=50

# --- Image OCR ---
# Engine: tesseract | gemini | auto  (auto = gemini if a key is set, else tesseract)
# PARSER_IMAGE_OCR_ENGINE=auto
# PARSER_TESSERACT_LANG=eng
# PARSER_IMAGE_OCR_TIMEOUT_S=120
# Gemini (requires `uv sync --extra gemini`):
# PARSER_GEMINI_API_KEY=
# PARSER_GEMINI_MODEL=gemini-2.5-flash
